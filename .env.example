# ── ローカル開発用の環境変数サンプル ──
# このファイルをコピーして .env を作成し、各値を埋めてください。
#   cp .env.example .env
# 詳細は manuals/environment.md を参照。

# 訪問者ID用キー（いいね機能で使用）。NEXT_PUBLIC_ なのでビルド時にJSバンドルへインライン化される公開値。
NEXT_PUBLIC_VISIT_ID_KEY=visit_id

# バックエンドAPI(Echo + Go)のベースURL。BFFプロキシが ${BACKEND_API_URL}/blogs のように連結する。
# ローカルはバックエンド(別リポジトリ)の起動先に合わせる。バックエンドのルーティングに /api プレフィックスがある場合は付与する。
BACKEND_API_URL=http://localhost:8080

# GitHub Markdownプロキシで許可するリポジトリオーナー（ホワイトリスト）。未設定かつ GITHUB_TOKEN ありは fail-closed で 500。
ALLOWED_REPO_OWNER=your-github-name

# GitHub APIトークン（Markdown取得用）。public リポジトリのみ読むなら空でも可。
GITHUB_TOKEN=
